# JWT — generá con: openssl rand -base64 32
JWT_SECRET="change-this-in-production"
JWT_REFRESH_SECRET="change-this-in-production-too"

NODE_ENV="development"

# CORS — origen permitido para requests del frontend
CORS_ORIGIN="http://localhost:3000"

# Upstash Redis — dejá vacío para usar rate limiting en memoria (solo dev)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Base de datos — SQLite para dev, PostgreSQL para prod
# DATABASE_URL="postgresql://user:password@localhost:5432/secureapi?schema=public"
