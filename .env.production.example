# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT VARIABLES
# Copiá este archivo, completá los valores y configuralo en Vercel Dashboard
# o con: vercel env add <VARIABLE_NAME>
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV="production"

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
# Recomendado: Neon (neon.tech) o Supabase (supabase.com) — ambos tienen free tier
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/secureapi?schema=public&sslmode=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generá con: openssl rand -base64 32
JWT_SECRET="reemplazar-con-secreto-seguro-openssl-rand-base64-32"
JWT_REFRESH_SECRET="reemplazar-con-otro-secreto-seguro-openssl-rand-base64-32"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dominio exacto de tu frontend — sin trailing slash
CORS_ORIGIN="https://tu-dominio.vercel.app"

# ── Rate limiting — Upstash Redis ─────────────────────────────────────────────
# Crear en: upstash.com → Redis → Create Database → REST API
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx"
